      "itemIdentifier": "cdif.bbr.metadata.DDEproperties.ddeImagery",
      "$schema": "metaschema.yaml",
      "name": "DDE Imagery Properties",
      "abstract": "Conditional extension for imagery resources using the CDIF provenance pattern (cdifProv). Maps DDE imagery acquisition metadata into prov:wasGeneratedBy activities: sensor, platform, equipment, and signalGenerator become typed instruments; collector becomes a participant with DataCollector role; startTime and endTime are activity temporal bounds. Wavelength and processedLevel remain as dataset-level schema:additionalProperty values. Defines properties: prov:wasGeneratedBy, schema:additionalProperty. Uses building blocks: instrument, agentInRole, person, organization, additionalProperty (schemaorgProperties).",
      "status": "under-development",
      "dateTimeAddition": "2026-02-28T00:00:00Z",
