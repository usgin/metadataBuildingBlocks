      "$schema": "metaschema.yaml",
      "name": "DDE Geoscience Discovery metadata",
      "abstract": "Gather building blocks to generate a DDE Geoscience Discovery record. Composes CDIF mandatory and optional properties with DDE required and optional extensions for geoscience metadata.",
