            }
          ]
        },
        "schema:description": {
          "type": "string"
        },
        "schema:alternateName": {
          "type": "string"
        },
        "schema:additionalType": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "schema:additionalProperty": {
          "type": "array",
          "items": {
