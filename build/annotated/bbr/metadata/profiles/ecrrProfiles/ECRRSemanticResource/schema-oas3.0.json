                  "$ref": "https://usgin.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/profiles/ecrrProfiles/ECRRSemanticResource/schema-oas3.0.json#/x-defs/cdif.bbr.metadata.ecrrProperties.ecrrAssessment/$defs/Organization"
