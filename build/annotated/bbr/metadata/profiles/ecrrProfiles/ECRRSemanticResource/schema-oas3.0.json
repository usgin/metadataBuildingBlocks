        "dct:conformsTo": {
          "description": "Specifications or standards that the resource conforms to. Array of labeled links.",
          "type": "array",
          "items": {
            "$ref": "https://usgin.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/profiles/ecrrProfiles/ECRRSemanticResource/schema-oas3.0.json#/x-defs/cdif.bbr.metadata.ecrrProperties.ecrrCommon/$defs/LabeledLink"
