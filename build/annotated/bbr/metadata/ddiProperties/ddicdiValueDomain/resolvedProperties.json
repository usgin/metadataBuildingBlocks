{"defs":{},"properties":[{"path":["cdi:platformType"],"description":"(SentinelValueDomain only) The type of software platform under which sentinel codes will be used. Statistical software platforms use different sets of codes to indicate missing values. Example values: SASNumeric, SPSSstyle, Rstyle, StataNumeric, BlankString, EmptyString, Unrestricted.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:takesConceptsFrom"],"description":"Reference to a conceptual domain (SubstantiveConceptualDomain or SentinelConceptualDomain) that provides conceptual grounding for this value domain (0..1). @id reference only.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:takesValuesFrom"],"description":"Enumeration domain providing the set of permissible coded values (0..1). Inline EnumerationDomain or @id reference.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:takesValuesFrom","cdi:identifier"],"description":"Formal identifier","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:takesValuesFrom","cdi:name"],"description":"Structured name for this enumeration domain","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:takesValuesFrom","cdi:name","cdi:context"],"description":"Context or usage of this name"},{"path":["cdi:takesValuesFrom","cdi:name","cdi:name"],"description":"The name string","required":true,"schema_type":"string"},{"path":["cdi:takesValuesFrom","cdi:purpose"],"description":"Purpose of this enumeration domain","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:takesValuesFrom","cdi:uses"],"description":"Reference to a LevelStructure that organizes the enumeration. @id reference only.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:takesValuesFrom","cdi:isDefinedBy"],"description":"References to Concepts that define the enumerated values. Array of @id references.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:takesValuesFrom","cdi:references"],"description":"Reference to the CategorySet providing the value categories. @id reference only.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:isDescribedBy"],"description":"Description of the value domain constraints (0..1). Inline ValueAndConceptDescription or @id reference.","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:isDescribedBy","cdi:classificationLevel"],"description":"Level of measurement","schema_type":"string","enum":["Continuous","Interval","Nominal","Ordinal","Ratio"],"sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:isDescribedBy","cdi:description"],"description":"Textual description of the value domain constraints","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:isDescribedBy","cdi:formatPattern"],"description":"Expected format pattern for values","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:isDescribedBy","cdi:identifier"],"description":"Formal identifier","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:isDescribedBy","cdi:logicalExpression"],"description":"Logical expression constraining valid values","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:isDescribedBy","cdi:maximumValueExclusive"],"description":"Exclusive upper bound for valid values","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:isDescribedBy","cdi:maximumValueInclusive"],"description":"Inclusive upper bound for valid values","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:isDescribedBy","cdi:minimumValueExclusive"],"description":"Exclusive lower bound for valid values","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:isDescribedBy","cdi:minimumValueInclusive"],"description":"Inclusive lower bound for valid values","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:isDescribedBy","cdi:regularExpression"],"description":"Regular expression constraining valid value syntax","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:isDescribedBy","cdi:regularExpression","cdi:content"],"description":"The string content","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:isDescribedBy","cdi:regularExpression","cdi:typeOfContent"],"description":"Type or format of the content","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:recommendedDataType"],"description":"Recommended physical data type for values in this domain","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:identifier"],"description":"Formal identifier for this value domain","sources":["bblocks://cdif.bbr.metadata.ddiProperties.ddicdiValueDomain"]},{"path":["cdi:identifier","cdi:nonDdiIdentifier"],"description":"Non-DDI identifier"},{"path":["cdi:identifier","cdi:nonDdiIdentifier","cdi:identifierContent"],"description":"The identifier value","required":true,"schema_type":"string"},{"path":["cdi:identifier","cdi:nonDdiIdentifier","cdi:managingAgency"],"description":"Agency managing this identifier scheme","schema_type":"string"},{"path":["cdi:identifier","cdi:uri"],"description":"URI form of the identifier","schema_type":"string","format":"uri"},{"path":["cdi:identifier","cdi:ddiIdentifier"],"description":"DDI-specific IRDI identifier"},{"path":["cdi:displayLabel"],"description