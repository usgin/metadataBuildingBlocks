"schema_type":"string"},{"path":["cdi:catalogDetails","cdi:creator","cdi:reference","cdi:description"],"description":"Human-readable description of the reference","schema_type":"string"},{"path":["cdi:catalogDetails","cdi:creator","cdi:reference","cdi:uri"],"description":"URI of the referenced entity","schema_type":"string","format":"uri"},{"path":["cdi:catalogDetails","cdi:creator","cdi:agentName"],"description":"Name of the agent"},{"path":["cdi:catalogDetails","cdi:identifier"],"description":"Catalog identifier","schema_type":"object"},{"path":["cdi:catalogDetails","cdi:identifier","cdi:isUri"],"schema_type":"boolean"},{"path":["cdi:catalogDetails","cdi:identifier","cdi:identifierContent"],"schema_type":"string"},{"path":["cdi:catalogDetails","cdi:summary"],"description":"Summary description"},{"path":["cdi:catalogDetails","cdi:title"],"description":"Title for the catalog entry"},{"path":["cdi:catalogDetails","cdi:title","cdi:languageSpecificString"],"description":"Language-tagged string value(s)"},{"path":["cdi:catalogDetails","cdi:title","cdi:languageSpecificString","cdi:content"],"description":"The text content","required":true,"schema_type":"string"},{"path":["cdi:catalogDetails","cdi:title","cdi:languageSpecificString","cdi:language"],"description":"ISO language code (e.g. en, fr, de)","schema_type":"string"}]}