<bblocks://cdif.bbr.metadata.ddiProperties.ddicdiActivity> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "DDI-CDI Activity" ;
    dct:abstract "DDI-CDI Activity class for CDIF metadata, describing tasks at a conceptual level using DDI-CDI vocabulary (cdi:Activity, cdi:Step, cdi:Parameter). Defines properties: @type, @id, cdi:name, cdi:description, cdi:definition, cdi:displayLabel, cdi:identifier, cdi:entityUsed, cdi:entityProduced, cdi:hasSubActivity, cdi:has_Step, cdi:standardModelMapping, cdi:start, cdi:end, cdi:hasInternal."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
