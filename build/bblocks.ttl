<bblocks://cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "CDIF Bioschemas Properties" ;
    dct:abstract "Bioschemas classes and properties for describing laboratory workflow provenance in CDIF metadata. Defines types from the Bioschemas and ARC Workflow Run RO-Crate profiles: bios:LabProcess (lab process execution), bios:LabProtocol (lab methodology), bios:Sample (physical sample), bios:FormalParameter (workflow parameter definition), bios:ComputationalWorkflow (computational workflow definition). Properties: bios:executesLabProtocol (link process to protocol), bios:parameterValue (actual parameter settings), bios:labEquipment (lab instruments on protocol), bios:computationalTool (software tools on protocol), bios:reagent (materials used). Based on the ARC Workflow Run RO-Crate profile (https://github.com/nfdi4plants/arc-wr-ro-crate-profile)."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2026-03-11T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "text/markdown" ;
            rdfs:isDefinedBy <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/generateddocs/markdown/bbr/metadata/bioschemasProperties/cdifBioschemasProperties/index.md> ],
        [ dct:format "application/json" ;
            rdfs:isDefinedBy <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/generateddocs/json-full/bbr/metadata/bioschemasProperties/cdifBioschemasProperties/index.json> ],
        [ dct:format "text/html" ;
            rdfs:isDefinedBy <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/bblock/cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties> ] ;
    dct:hasVersion "0.1" ;
    dct:modified "2026-03-30"^^xsd:date ;
    dct:source <https://bioschemas.org/profiles/LabProcess>,
        <https://bioschemas.org/profiles/LabProtocol>,
        <https://github.com/nfdi4plants/arc-wr-ro-crate-profile>,
        <https://www.researchobject.org/workflow-run-crate/> ;
    skos:inScheme <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/> ;
    skos:prefLabel "CDIF Bioschemas Properties" ;
    skos:topConceptOf <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/> ;
    dcat:keyword "ARC",
        "CDIF",
        "LabProcess",
        "LabProtocol",
        "WRROC",
        "bioschemas",
        "laboratory",
        "provenance" ;
    prof:hasResource [ dct:conformsTo shacl: ;
            dct:format "text/turtle" ;
            rdfs:seeAlso <bblocks://cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties> ;
            prof:hasArtifact <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/_sources/bioschemasProperties/cdifBioschemasProperties/rules.shacl> ;
