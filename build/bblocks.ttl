<bblocks://cdif.bbr.metadata.adaProperties.details> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "Instrument Detail Types" ;
    dct:abstract "Instrument-specific detail types for ADA analytical techniques. Defines types: detailBasemap, detailARGT, detailDSC, detailEMPA, detailEAIRMS, detailICPOES, detailL2MS, detailLAF, detailNanoIR, detailNanoSIMS, detailPSFD, detailVNMIR, detailQRIS, detailSLS, detailXCT, detailXRD. Uses building blocks: detailBasemap (adaProperties), detailARGT (adaProperties), detailDSC (adaProperties), detailEMPA (adaProperties), detailEAIRMS (adaProperties), detailICPOES (adaProperties), detailL2MS (adaProperties), detailLAF (adaProperties), detailNanoIR (adaProperties), detailNanoSIMS (adaProperties), detailPSFD (adaProperties), detailVNMIR (adaProperties), detailQRIS (adaProperties), detailSLS (adaProperties), detailXCT (adaProperties), detailXRD (adaProperties)."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2026-02-05T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "application/json" ;
            rdfs:isDefinedBy <https://usgin.github.io/metadataBuildingBlocks/build/generateddocs/json-full/bbr/metadata/adaProperties/details/index.json> ],
        [ dct:format "text/markdown" ;
            rdfs:isDefinedBy <https://usgin.github.io/metadataBuildingBlocks/build/generateddocs/markdown/bbr/metadata/adaProperties/details/index.md> ],
        [ dct:format "text/html" ;
            rdfs:isDefinedBy <https://usgin.github.io/metadataBuildingBlocks/bblock/cdif.bbr.metadata.adaProperties.details> ] ;
    dct:hasVersion "0.1" ;
    dct:modified "2026-03-04"^^xsd:date ;
    dct:source <https://github.com/amds-ldeo/metadata> ;
    skos:inScheme <https://usgin.github.io/metadataBuildingBlocks/> ;
    skos:prefLabel "Instrument Detail Types" ;
    skos:topConceptOf <https://usgin.github.io/metadataBuildingBlocks/> ;
    dcat:keyword "ada",
        "astromat",
        "details",
        "instrument" ;
    prof:hasResource [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
            dct:format "application/json" ;
            prof:hasArtifact <https://usgin.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/adaProperties/details/schema.json> ;
            prof:hasRole role:schema ],
        [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
