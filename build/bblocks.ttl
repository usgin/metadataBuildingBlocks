<bblocks://cdif.bbr.metadata.ddiProperties.ddicdiProv> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "DDI-CDI Provenance Activity" ;
    dct:abstract "DDI-CDI native provenance activity for CDIF metadata, expressing workflows, agents, instruments, and methodology using DDI-CDI vocabulary (cdi:Activity, cdi:Step, cdi:ProcessingAgent). Defines properties: @type, @id, cdi:name, cdi:description, cdi:displayLabel, cdi:identifier, cdi:entityUsed, cdi:entityProduced, cdi:hasSubActivity, cdi:has_Step, cdi:standardModelMapping."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2026-02-25T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "text/html" ;
            rdfs:isDefinedBy <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/bblock/cdif.bbr.metadata.ddiProperties.ddicdiProv> ],
