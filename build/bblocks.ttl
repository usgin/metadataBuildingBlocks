<bblocks://cdif.bbr.metadata.cdifProperties.cdifLongData> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "CDIF Long Data Structure" ;
    dct:abstract "metadata to document long (narrow) data structure where each row is a single observation with a descriptor column identifying the variable and a reference column holding the value. Defines properties: @type, cdi:hasPhysicalMapping, cdi:arrayBase, csvw:delimiter, csvw:header, csvw:headerRowCount, csvw:commentPrefix, csvw:skipBlankRows, csvw:skipInitialSpace, csvw:skipRows, csvw:lineTerminators, csvw:quoteChar, cdi:isDelimited, cdi:isFixedWidth, cdi:escapeCharacter. Uses building blocks: cdifPhysicalMapping (cdifProperties)."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2026-02-24T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "text/html" ;
            rdfs:isDefinedBy <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/bblock/cdif.bbr.metadata.cdifProperties.cdifLongData> ],
