<bblocks://cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "CDIF Bioschemas Properties" ;
    dct:abstract "Bioschemas classes and properties for describing laboratory workflow provenance in CDIF metadata. Defines types from the Bioschemas and ARC Workflow Run RO-Crate profiles: bios:LabProcess (lab process execution), bios:LabProtocol (lab methodology), bios:Sample (physical sample), bios:FormalParameter (workflow parameter definition), bios:ComputationalWorkflow (computational workflow definition). Properties: bios:executesLabProtocol (link process to protocol), bios:parameterValue (actual parameter settings), bios:labEquipment (lab instruments on protocol), bios:computationalTool (software tools on protocol), bios:reagent (materials used). Based on the ARC Workflow Run RO-Crate profile (https://github.com/nfdi4plants/arc-wr-ro-crate-profile)."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2026-03-11T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "application/json" ;
            rdfs:isDefinedBy <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/generateddocs/json-full/bbr/metadata/bioschemasProperties/cdifBioschemasProperties/index.json> ],
        [ dct:format "text/markdown" ;
            rdfs:isDefinedBy <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/generateddocs/markdown/bbr/metadata/bioschemasProperties/cdifBioschemasProperties/index.md> ],
        [ dct:format "text/html" ;
            rdfs:isDefinedBy <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/bblock/cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties> ] ;
    dct:hasVersion "0.1" ;
    dct:modified "2026-03-19"^^xsd:date ;
    dct:source <https://bioschemas.org/profiles/LabProcess>,
        <https://bioschemas.org/profiles/LabProtocol>,
        <https://github.com/nfdi4plants/arc-wr-ro-crate-profile>,
        <https://www.researchobject.org/workflow-run-crate/> ;
    skos:inScheme <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/> ;
    skos:prefLabel "CDIF Bioschemas Properties" ;
    skos:topConceptOf <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/> ;
    dcat:keyword "ARC",
        "CDIF",
        "LabProcess",
        "LabProtocol",
        "WRROC",
        "bioschemas",
        "laboratory",
        "provenance" ;
    prof:hasResource [ dct:conformsTo <https://www.w3.org/TR/json-ld11/> ;
            dct:format "application/ld+json" ;
            prof:hasArtifact <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/bioschemasProperties/cdifBioschemasProperties/context.jsonld> ;
            prof:hasRole role:mapping ],
        [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
            dct:format "application/yaml" ;
            prof:hasArtifact <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/bioschemasProperties/cdifBioschemasProperties/schema.yaml> ;
            prof:hasRole role:schema ],
        [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
            dct:format "application/json" ;
            prof:hasArtifact <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/bioschemasProperties/cdifBioschemasProperties/schema.json> ;
            prof:hasRole role:schema ],
        [ dct:conformsTo shacl: ;
            dct:format "text/turtle" ;
            rdfs:seeAlso <bblocks://cdif.bbr.metadata.bioschemasProperties.cdifBioschemasProperties> ;
            prof:hasArtifact <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/_sources/bioschemasProperties/cdifBioschemasProperties/rules.shacl> ;
            prof:hasRole role:validation ] ;
    bblocks:hasSourceJsonLdContext <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/_sources/bioschemasProperties/cdifBioschemasProperties/context.jsonld> ;
    bblocks:scope <http://www.opengis.net/def/bblocks/scope/unstable> ;
    bblocks:status <http://www.opengis.net/def/status/under-development> ;
    bblocks:validationPassed true .

<bblocks://cdif.bbr.metadata.cdifProperties.cdifLongData> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "CDIF Long Data Structure" ;
    dct:abstract "metadata to document long (narrow) data structure where each row is a single observation with a descriptor column identifying the variable and a reference column holding the value. Defines properties: @type, cdi:hasPhysicalMapping, cdi:arrayBase, csvw:delimiter, csvw:header, csvw:headerRowCount, csvw:commentPrefix, csvw:skipBlankRows, csvw:skipInitialSpace, csvw:skipRows, csvw:lineTerminators, csvw:quoteChar, cdi:isDelimited, cdi:isFixedWidth, cdi:escapeCharacter. Uses building blocks: cdifPhysicalMapping (cdifProperties)."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2026-02-24T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "text/markdown" ;
            rdfs:isDefinedBy <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/generateddocs/markdown/bbr/metadata/cdifProperties/cdifLongData/index.md> ],
        [ dct:format "text/html" ;
            rdfs:isDefinedBy <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/bblock/cdif.bbr.metadata.cdifProperties.cdifLongData> ],
        [ dct:format "application/json" ;
            rdfs:isDefinedBy <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/generateddocs/json-full/bbr/metadata/cdifProperties/cdifLongData/index.json> ] ;
    dct:hasVersion "0.1" ;
    dct:modified "2026-03-19"^^xsd:date ;
    dct:source <https://ddialliance.org/Specification/DDI-CDI/1.0/> ;
    skos:inScheme <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/> ;
    skos:prefLabel "CDIF Long Data Structure" ;
    skos:topConceptOf <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/> ;
    dcat:keyword "cdif",
        "ddi-cdi",
        "long-data" ;
    prof:hasResource [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
            dct:format "application/json" ;
            prof:hasArtifact <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/cdifProperties/cdifLongData/schema.json> ;
            prof:hasRole role:schema ],
        [ dct:conformsTo <https://www.w3.org/TR/json-ld11/> ;
            dct:format "application/ld+json" ;
            prof:hasArtifact <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/cdifProperties/cdifLongData/context.jsonld> ;
            prof:hasRole role:mapping ],
        [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
            dct:format "application/yaml" ;
            prof:hasArtifact <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/build/annotated/bbr/metadata/cdifProperties/cdifLongData/schema.yaml> ;
            prof:hasRole role:schema ],
        [ dct:conformsTo shacl: ;
            dct:format "text/turtle" ;
            rdfs:seeAlso <bblocks://cdif.bbr.metadata.cdifProperties.cdifLongData> ;
            prof:hasArtifact <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/_sources/cdifProperties/cdifLongData/rules.shacl> ;
            prof:hasRole role:validation ],
        [ dct:conformsTo shacl: ;
            dct:format "text/turtle" ;
            rdfs:seeAlso <bblocks://cdif.bbr.metadata.cdifProperties.cdifPhysicalMapping> ;
            prof:hasArtifact <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/_sources/cdifProperties/cdifPhysicalMapping/rules.shacl> ;
            prof:hasRole role:validation ] ;
    bblocks:dependsOn <bblocks://cdif.bbr.metadata.cdifProperties.cdifPhysicalMapping> ;
    bblocks:hasSourceJsonLdContext <https://cross-domain-interoperability-framework.github.io/metadataBuildingBlocks/_sources/cdifProperties/cdifLongData/context.jsonld> ;
    bblocks:scope <http://www.opengis.net/def/bblocks/scope/unstable> ;
    bblocks:status <http://www.opengis.net/def/status/under-development> ;
    bblocks:validationPassed true .

<bblocks://cdif.bbr.metadata.cdifProperties.cdifVariableMeasured> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "VariableMeasured with DDI-CDI extensions" ;
    dct:abstract "Schema defining properties for schema.org variableMeasured with some DDI-CDI properties, for implementation of CDIF discovery XAS profile. Implemented as schema.org/PropertyValue. Defines properties: @type, cdi:identifier, cdi:physicalDataType, cdi:intendedDataType, cdi:role, cdi:describedUnitOfMeasure, cdi:simpleUnitOfMeasure, cdi:uses, cdi:name, cdi:displayLabel. Uses building blocks: definedTerm (schemaorgProperties), variableMeasured (schemaorgProperties)."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
