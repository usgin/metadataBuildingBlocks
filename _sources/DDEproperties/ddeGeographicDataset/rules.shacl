@prefix rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:        <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:          <http://www.w3.org/ns/shacl#> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix schema:      <http://schema.org/>.
@prefix cdifd: <https://cdif.org/validation/0.1/shacl#> .
@base <https://www.ogc.org/rules/template/> .

# Geographic dataset properties validation is conditional --
# only applies when the resource is classified as a geographic dataset type.
# The spatialCoverage requirement is enforced by JSON Schema (required property).
# SHACL validates that Place nodes have meaningful geo content.

cdifd:DDEGeographicDatasetPlaceShape
    a sh:NodeShape ;
    sh:targetClass schema:Place ;
    sh:property [
        sh:path schema:geo ;
        sh:minCount 1 ;
        sh:message "a geographic dataset Place must have a schema:geo property with a GeoShape or GeoCoordinates" ;
    ] ;
    .
