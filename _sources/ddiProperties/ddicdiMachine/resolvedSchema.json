{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DDI-CDI Machine",
  "description": "DDI-CDI Machine agent (cls-Machine, extends Agent). Represents software or hardware with access location, function, and interface specifications.",
  "type": "object",
  "properties": {
    "@type": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "contains": {
        "const": "cdi:Machine"
      },
      "minItems": 1
    },
    "@id": {
      "type": "string",
      "description": "Identifier for this machine node"
    },
    "cdi:accessLocation": {
      "type": "object",
      "description": "Network or physical access point for this machine",
      "properties": {
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "cdi:AccessLocation"
          },
          "minItems": 1
        },
        "cdi:uri": {
          "type": "string",
          "format": "uri",
          "description": "URI of the access endpoint"
        },
        "cdi:mimeType": {
          "$comment": "unresolved fragment ref: #/$defs/ControlledVocabularyEntry",
          "description": "MIME type of the resource at this location"
        },
        "cdi:physicalLocation": {
          "$comment": "unresolved fragment ref: #/$defs/InternationalString",
          "description": "Physical location description"
        }
      }
    },
    "cdi:function": {
      "type": "object",
      "description": "Function performed by this machine",
      "properties": {
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "cdi:ControlledVocabularyEntry"
          },
          "minItems": 1
        },
        "cdi:entryValue": {
          "type": "string",
          "description": "The vocabulary code or value"
        },
        "cdi:name": {
          "type": "string",
          "description": "Human-readable name"
        },
        "cdi:vocabulary": {
          "$comment": "unresolved fragment ref: #/$defs/Reference",
          "description": "Reference to the vocabulary scheme"
        }
      }
    },
    "cdi:machineInterface": {
      "type": "object",
      "description": "Interface type for this machine",
      "properties": {
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "cdi:ControlledVocabularyEntry"
          },
          "minItems": 1
        },
        "cdi:entryValue": {
          "type": "string",
          "description": "The vocabulary code or value"
        },
        "cdi:name": {
          "type": "string",
          "description": "Human-readable name"
        },
        "cdi:vocabulary": {
          "$comment": "unresolved fragment ref: #/$defs/Reference",
          "description": "Reference to the vocabulary scheme"
        }
      }
    },
    "cdi:name": {
      "description": "Name(s) of this machine",
      "anyOf": [
        {
          "type": "object",
          "description": "DDI-CDI structured name wrapper (dt-ObjectName)",
          "properties": {
            "@type": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "contains": {
                "const": "cdi:ObjectName"
              },
              "minItems": 1
            },
            "cdi:name": {
              "type": "string",
              "description": "The name string"
            },
            "cdi:context": {
              "$comment": "unresolved fragment ref: #/$defs/ControlledVocabularyEntry",
              "description": "Context or usage of this name"
            }
          },
          "required": [
            "cdi:name"
          ]
        },
        {
          "type": "array",
          "items": {
            "type": "object",
            "description": "DDI-CDI structured name wrapper (dt-ObjectName)",
            "properties": {
              "@type": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "contains": {
                  "const": "cdi:ObjectName"
                },
                "minItems": 1
              },
              "cdi:name": {
                "type": "string",
                "description": "The name string"
              },
              "cdi:context": {
                "$comment": "unresolved fragment ref: #/$defs/ControlledVocabularyEntry",
                "description": "Context or usage of this name"
              }
            },
            "required": [
              "cdi:name"
            ]
          }
        }
      ]
    },
    "cdi:ownerOperatorContact": {
      "type": "object",
      "description": "Contact information for the owner or operator",
      "properties": {
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "cdi:ContactInformation"
          },
          "minItems": 1
        },
        "cdi:address": {
          "description": "Postal address(es)",
          "anyOf": [
            {
              "type": "object",
              "description": "DDI-CDI postal address (dt-Address)",
              "properties": {
                "@type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "contains": {
                    "const": "cdi:Address"
                  },
                  "minItems": 1
                },
                "cdi:line": {
                  "description": "Address line(s)",
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  ]
                },
                "cdi:cityPlaceLocal": {
                  "type": "string",
                  "description": "City, town, or locality"
                },
                "cdi:stateProvince": {
                  "type": "string",
                  "description": "State, province, or region"
                },
                "cdi:postalCode": {
                  "type": "string",
                  "description": "Postal or ZIP code"
                },
                "cdi:countryCode": {
                  "$comment": "unresolved fragment ref: #/$defs/ControlledVocabularyEntry",
                  "description": "Country code"
                },
                "cdi:typeOfAddress": {
                  "$comment": "unresolved fragment ref: #/$defs/ControlledVocabularyEntry",
                  "description": "Type of address (e.g. home, work, mailing)"
                },
                "cdi:isPreferred": {
                  "type": "boolean",
                  "default": false,
                  "description": "Whether this is the preferred address"
                }
              }
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "description": "DDI-CDI postal address (dt-Address)",
                "properties": {
                  "@type": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "contains": {
                      "const": "cdi:Address"
                    },
                    "minItems": 1
                  },
                  "cdi:line": {
                    "description": "Address line(s)",
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    ]
                  },
                  "cdi:cityPlaceLocal": {
                    "type": "string",
                    "description": "City, town, or locality"
                  },
                  "cdi:stateProvince": {
                    "type": "string",
                    "description": "State, province, or region"
                  },
                  "cdi:postalCode": {
                    "type": "string",
                    "description": "Postal or ZIP code"
                  },
                  "cdi:countryCode": {
                    "$comment": "unresolved fragment ref: #/$defs/ControlledVocabularyEntry",
                    "description": "Country code"
                  },
                  "cdi:typeOfAddress": {
                    "$comment": "unresolved fragment ref: #/$defs/ControlledVocabularyEntry",
                    "description": "Type of address (e.g. home, work, mailing)"
                  },
                  "cdi:isPreferred": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether this is the preferred address"
                  }
                }
              }
            }
          ]
        },
        "cdi:email": {
          "description": "Email address(es)",
          "anyOf": [
            {
              "type": "object",
              "description": "DDI-CDI email address (dt-Email)",
              "properties": {
                "@type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "contains": {
                    "const": "cdi:Email"
                  },
                  "minItems": 1
                },
                "cdi:internetEmail": {
                  "type": "string",
                  "description": "Email address string"
                },
                "cdi:typeOfEmail": {
                  "$comment": "unresolved fragment ref: #/$defs/ControlledVocabularyEntry",
                  "description": "Type of email (e.g. personal, work)"
                },
                "cdi:isPreferred": {
                  "type": "boolean",
                  "default": false,
                  "description": "Whether this is the preferred email"
                }
              }
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "description": "DDI-CDI email address (dt-Email)",
                "properties": {
                  "@type": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "contains": {
                      "const": "cdi:Email"
                    },
                    "minItems": 1
                  },
                  "cdi:internetEmail": {
                    "type": "string",
                    "description": "Email address string"
                  },
                  "cdi:typeOfEmail": {
                    "$comment": "unresolved fragment ref: #/$defs/ControlledVocabularyEntry",
                    "description": "Type of email (e.g. personal, work)"
                  },
                  "cdi:isPreferred": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether this is the preferred email"
                  }
                }
              }
            }
          ]
        },
        "cdi:emessaging": {
          "description": "Electronic messaging contact(s)",
          "anyOf": [
            {
              "type": "object",
              "description": "DDI-CDI electronic messaging system contact (dt-ElectronicMessageSystem)",
              "properties": {
                "@type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "contains": {
                    "const": "cdi:ElectronicMessageSystem"
                  },
                  "minItems": 1
                },
                "cdi:contactAddress": {
                  "type": "string",
                  "description": "Messaging address or handle"
                },
                "cdi:typeOfService": {
                  "$comment": "unresolved fragment ref: #/$defs/ControlledVocabularyEntry",
                  "description": "Type of messaging service (e.g. Slack, Teams)"
                },
                "cdi:isPreferred": {
                  "type": "boolean",
                  "default": false,
                  "description": "Whether this is the preferred messaging service"
                }
              }
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "description": "DDI-CDI electronic messaging system contact (dt-ElectronicMessageSystem)",
                "properties": {
                  "@type": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "contains": {
                      "const": "cdi:ElectronicMessageSystem"
                    },
                    "minItems": 1
                  },
                  "cdi:contactAddress": {
                    "type": "string",
                    "description": "Messaging address or handle"
                  },
                  "cdi:typeOfService": {
                    "$comment": "unresolved fragment ref: #/$defs/ControlledVocabularyEntry",
                    "description": "Type of messaging service (e.g. Slack, Teams)"
                  },
                  "cdi:isPreferred": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether this is the preferred messaging service"
                  }
                }
              }
            }
          ]
        },
        "cdi:telephone": {
          "description": "Telephone number(s)",
          "anyOf": [
            {
              "type": "object",
              "description": "DDI-CDI telephone number (dt-Telephone)",
              "properties": {
                "@type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "contains": {
                    "const": "cdi:Telephone"
                  },
                  "minItems": 1
                },
                "cdi:telephoneNumber": {
                  "type": "string",
                  "description": "Telephone number string"
                },
                "cdi:typeOfTelephone": {
                  "$comment": "unresolved fragment ref: #/$defs/ControlledVocabularyEntry",
                  "description": "Type of telephone (e.g. mobile, office, fax)"
                },
                "cdi:isPreferred": {
                  "type": "boolean",
                  "default": false,
                  "description": "Whether this is the preferred telephone"
                }
              }
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "description": "DDI-CDI telephone number (dt-Telephone)",
                "properties": {
                  "@type": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "contains": {
                      "const": "cdi:Telephone"
                    },
                    "minItems": 1
                  },
                  "cdi:telephoneNumber": {
                    "type": "string",
                    "description": "Telephone number string"
                  },
                  "cdi:typeOfTelephone": {
                    "$comment": "unresolved fragment ref: #/$defs/ControlledVocabularyEntry",
                    "description": "Type of telephone (e.g. mobile, office, fax)"
                  },
                  "cdi:isPreferred": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether this is the preferred telephone"
                  }
                }
              }
            }
          ]
        },
        "cdi:website": {
          "description": "Website link(s)",
          "anyOf": [
            {
              "type": "object",
              "description": "DDI-CDI website link (dt-WebLink)",
              "properties": {
                "@type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "contains": {
                    "const": "cdi:WebLink"
                  },
                  "minItems": 1
                },
                "cdi:uri": {
                  "type": "string",
                  "format": "uri",
                  "description": "URI of the website"
                },
                "cdi:typeOfWebsite": {
                  "$comment": "unresolved fragment ref: #/$defs/ControlledVocabularyEntry",
                  "description": "Type of website (e.g. homepage, documentation)"
                },
                "cdi:isPreferred": {
                  "type": "boolean",
                  "default": false,
                  "description": "Whether this is the preferred website"
                }
              }
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "description": "DDI-CDI website link (dt-WebLink)",
                "properties": {
                  "@type": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "contains": {
                      "const": "cdi:WebLink"
                    },
                    "minItems": 1
                  },
                  "cdi:uri": {
                    "type": "string",
                    "format": "uri",
                    "description": "URI of the website"
                  },
                  "cdi:typeOfWebsite": {
                    "$comment": "unresolved fragment ref: #/$defs/ControlledVocabularyEntry",
                    "description": "Type of website (e.g. homepage, documentation)"
                  },
                  "cdi:isPreferred": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether this is the preferred website"
                  }
                }
              }
            }
          ]
        }
      }
    },
    "cdi:typeOfMachine": {
      "type": "object",
      "description": "Classification of this machine",
      "properties": {
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "cdi:ControlledVocabularyEntry"
          },
          "minItems": 1
        },
        "cdi:entryValue": {
          "type": "string",
          "description": "The vocabulary code or value"
        },
        "cdi:name": {
          "type": "string",
          "description": "Human-readable name"
        },
        "cdi:vocabulary": {
          "$comment": "unresolved fragment ref: #/$defs/Reference",
          "description": "Reference to the vocabulary scheme"
        }
      }
    },
    "cdi:catalogDetails": {
      "type": "object",
      "description": "Catalog metadata for this agent",
      "properties": {
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "cdi:CatalogDetails"
          },
          "minItems": 1
        },
        "cdi:title": {
          "$comment": "unresolved fragment ref: #/$defs/InternationalString",
          "description": "Title for the catalog entry"
        },
        "cdi:summary": {
          "$comment": "unresolved fragment ref: #/$defs/InternationalString",
          "description": "Summary description"
        },
        "cdi:identifier": {
          "description": "Catalog identifier",
          "type": "object",
          "properties": {
            "cdi:identifierContent": {
              "type": "string"
            },
            "cdi:isUri": {
              "type": "boolean"
            }
          }
        },
        "cdi:creator": {
          "$comment": "unresolved fragment ref: #/$defs/AgentInRole",
          "description": "Creator of the catalog entry"
        }
      }
    },
    "cdi:identifier": {
      "type": "object",
      "description": "Formal identifier for this agent",
      "properties": {
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "cdi:Identifier"
          },
          "minItems": 1
        },
        "cdi:ddiIdentifier": {
          "$comment": "unresolved fragment ref: #/$defs/InternationalRegistrationDataIdentifier",
          "description": "DDI-specific IRDI identifier"
        },
        "cdi:uri": {
          "type": "string",
          "format": "uri",
          "description": "URI form of the identifier"
        },
        "cdi:nonDdiIdentifier": {
          "description": "Non-DDI identifier",
          "anyOf": [
            {
              "type": "object",
              "description": "Non-DDI identifier (dt-NonDdiIdentifier)",
              "properties": {
                "@type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "contains": {
                    "const": "cdi:NonDdiIdentifier"
                  },
                  "minItems": 1
                },
                "cdi:identifierContent": {
                  "type": "string",
                  "description": "The identifier value"
                },
                "cdi:managingAgency": {
                  "type": "string",
                  "description": "Agency managing this identifier scheme"
                }
              },
              "required": [
                "cdi:identifierContent"
              ]
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "description": "Non-DDI identifier (dt-NonDdiIdentifier)",
                "properties": {
                  "@type": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "contains": {
                      "const": "cdi:NonDdiIdentifier"
                    },
                    "minItems": 1
                  },
                  "cdi:identifierContent": {
                    "type": "string",
                    "description": "The identifier value"
                  },
                  "cdi:managingAgency": {
                    "type": "string",
                    "description": "Agency managing this identifier scheme"
                  }
                },
                "required": [
                  "cdi:identifierContent"
                ]
              }
            }
          ]
        }
      }
    },
    "cdi:image": {
      "type": "object",
      "description": "Image associated with this agent",
      "properties": {
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "cdi:PrivateImage"
          },
          "minItems": 1
        },
        "cdi:effectiveDates": {
          "$comment": "unresolved fragment ref: #/$defs/DateRange",
          "description": "Date range when this image is effective"
        },
        "cdi:privacy": {
          "$comment": "unresolved fragment ref: #/$defs/ControlledVocabularyEntry",
          "description": "Privacy classification"
        }
      }
    },
    "cdi:purpose": {
      "type": "object",
      "description": "Purpose or role of this agent",
      "properties": {
        "@type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "cdi:InternationalString"
          },
          "minItems": 1
        },
        "cdi:languageSpecificString": {
          "description": "Language-tagged string value(s)",
          "anyOf": [
            {
              "type": "object",
              "description": "DDI-CDI language-tagged string (dt-LanguageString)",
              "properties": {
                "@type": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "contains": {
                    "const": "cdi:LanguageString"
                  },
                  "minItems": 1
                },
                "cdi:content": {
                  "type": "string",
                  "description": "The text content"
                },
                "cdi:language": {
                  "type": "string",
                  "description": "ISO language code (e.g. en, fr, de)"
                }
              },
              "required": [
                "cdi:content"
              ]
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "description": "DDI-CDI language-tagged string (dt-LanguageString)",
                "properties": {
                  "@type": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "contains": {
                      "const": "cdi:LanguageString"
                    },
                    "minItems": 1
                  },
                  "cdi:content": {
                    "type": "string",
                    "description": "The text content"
                  },
                  "cdi:language": {
                    "type": "string",
                    "description": "ISO language code (e.g. en, fr, de)"
                  }
                },
                "required": [
                  "cdi:content"
                ]
              }
            }
          ]
        }
      }
    }
  },
  "required": [
    "@type"
  ]
}
