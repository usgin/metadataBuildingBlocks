@prefix rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:        <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:          <http://www.w3.org/ns/shacl#> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix cdi:         <http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/> .
@prefix cdifd: <https://cdif.org/validation/0.1/shacl#> .
@base <https://www.ogc.org/rules/template/> .


# ------------------------------------------------------------
# Individual shape -- validates DDI-CDI Individual (person) nodes
# ------------------------------------------------------------

cdifd:ddicdiIndividualShape
	a sh:NodeShape ;
	sh:targetClass cdi:Individual ;

	# -- RECOMMENDED (Warning) --

	sh:property [
		sh:path cdi:individualName ;
		sh:minCount 1 ;
		sh:severity sh:Warning ;
		sh:message "A DDI-CDI Individual should have at least one cdi:individualName" ;
	] ;

	# -- INFORMATIONAL (Info) --

	sh:property [
		sh:path cdi:contactInformation ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI Individual may include cdi:contactInformation" ;
	] ;

	sh:property [
		sh:path cdi:identifier ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI Individual may include a cdi:identifier" ;
	] ;
	.


# ------------------------------------------------------------
# Machine shape -- validates DDI-CDI Machine (software/hardware) nodes
# ------------------------------------------------------------

cdifd:ddicdiMachineShape
	a sh:NodeShape ;
	sh:targetClass cdi:Machine ;

	# -- RECOMMENDED (Warning) --

	sh:property [
		sh:path cdi:name ;
		sh:minCount 1 ;
		sh:severity sh:Warning ;
		sh:message "A DDI-CDI Machine should have at least one cdi:name (ObjectName)" ;
	] ;

	# -- INFORMATIONAL (Info) --

	sh:property [
		sh:path cdi:typeOfMachine ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI Machine may include a cdi:typeOfMachine classification" ;
	] ;

	sh:property [
		sh:path cdi:accessLocation ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI Machine may include a cdi:accessLocation" ;
	] ;

	sh:property [
		sh:path cdi:identifier ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI Machine may include a cdi:identifier" ;
	] ;
	.


# ------------------------------------------------------------
# Organization shape -- validates DDI-CDI Organization nodes
# ------------------------------------------------------------

cdifd:ddicdiOrganizationShape
	a sh:NodeShape ;
	sh:targetClass cdi:Organization ;

	# -- RECOMMENDED (Warning) --

	sh:property [
		sh:path cdi:organizationName ;
		sh:minCount 1 ;
		sh:severity sh:Warning ;
		sh:message "A DDI-CDI Organization should have at least one cdi:organizationName" ;
	] ;

	# -- INFORMATIONAL (Info) --

	sh:property [
		sh:path cdi:contactInformation ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI Organization may include cdi:contactInformation" ;
	] ;

	sh:property [
		sh:path cdi:identifier ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI Organization may include a cdi:identifier" ;
	] ;
	.


# ------------------------------------------------------------
# ProcessingAgent shape -- validates DDI-CDI ProcessingAgent nodes
# ------------------------------------------------------------

cdifd:ddicdiProcessingAgentShape
	a sh:NodeShape ;
	sh:targetClass cdi:ProcessingAgent ;

	# -- RECOMMENDED (Warning) --

	sh:property [
		sh:path cdi:performs ;
		sh:minCount 1 ;
		sh:or (
			[sh:nodeKind sh:IRI ;]
			[sh:nodeKind sh:BlankNode ;]
		) ;
		sh:severity sh:Warning ;
		sh:message "A DDI-CDI ProcessingAgent should specify at least one activity it performs" ;
	] ;

	# -- INFORMATIONAL (Info) --

	sh:property [
		sh:path cdi:operatesOn ;
		sh:or (
			[sh:nodeKind sh:IRI ;]
			[sh:nodeKind sh:BlankNode ;]
		) ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI ProcessingAgent may specify cdi:operatesOn (ProductionEnvironment)" ;
	] ;

	sh:property [
		sh:path cdi:identifier ;
		sh:severity sh:Info ;
		sh:message "A DDI-CDI ProcessingAgent may include a cdi:identifier" ;
	] ;
	.
